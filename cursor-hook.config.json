{
  "files": {
    "hooks": [
      "hooks/mx-master-haptic"
    ]
  },
  "hooks": {
    "stop": [
      {
        "command": "node ./haptic.js completed"
      }
    ],
    "afterAgentResponse": [
      {
        "command": "node ./haptic.js knock"
      }
    ],
    "postToolUseFailure": [
      {
        "command": "node ./haptic.js angry_alert"
      }
    ],
    "subagentStop": [
      {
        "command": "node ./haptic.js sharp_state_change"
      }
    ]
  }
}
