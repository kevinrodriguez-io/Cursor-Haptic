{
  "version": 1,
  "hooks": {
    "agentStop": [
      {
        "type": "command",
        "command": "node \"${PLUGIN_ROOT}/scripts/run-haptic.js\" completed",
        "bash": "node \"${PLUGIN_ROOT:-${COPILOT_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}}/scripts/run-haptic.js\" completed",
        "powershell": "$r = $env:PLUGIN_ROOT; if (-not $r) { $r = $env:COPILOT_PLUGIN_ROOT }; if (-not $r) { $r = $env:CLAUDE_PLUGIN_ROOT }; node \"$r/scripts/run-haptic.js\" completed",
        "cwd": "${PLUGIN_ROOT}",
        "timeoutSec": 5
      }
    ],
    "postToolUseFailure": [
      {
        "type": "command",
        "command": "node \"${PLUGIN_ROOT}/scripts/run-haptic.js\" angry_alert",
        "bash": "node \"${PLUGIN_ROOT:-${COPILOT_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}}/scripts/run-haptic.js\" angry_alert",
        "powershell": "$r = $env:PLUGIN_ROOT; if (-not $r) { $r = $env:COPILOT_PLUGIN_ROOT }; if (-not $r) { $r = $env:CLAUDE_PLUGIN_ROOT }; node \"$r/scripts/run-haptic.js\" angry_alert",
        "cwd": "${PLUGIN_ROOT}",
        "timeoutSec": 5
      }
    ],
    "subagentStop": [
      {
        "type": "command",
        "command": "node \"${PLUGIN_ROOT}/scripts/run-haptic.js\" sharp_state_change",
        "bash": "node \"${PLUGIN_ROOT:-${COPILOT_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}}/scripts/run-haptic.js\" sharp_state_change",
        "powershell": "$r = $env:PLUGIN_ROOT; if (-not $r) { $r = $env:COPILOT_PLUGIN_ROOT }; if (-not $r) { $r = $env:CLAUDE_PLUGIN_ROOT }; node \"$r/scripts/run-haptic.js\" sharp_state_change",
        "cwd": "${PLUGIN_ROOT}",
        "timeoutSec": 5
      }
    ]
  }
}
